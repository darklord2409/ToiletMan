# Copy to .env.local for local dev. In production these are set directly in
# docker-compose.prod.yml's `website` service (see root docker-compose.prod.yml).

# Server-side only -- Docker-internal backend URL, never sent to the browser.
BACKEND_INTERNAL_URL=http://localhost:8000

# Sent to the browser -- both point at same-origin paths that Caddy (prod) /
# this app's own rewrites (dev) forward to the backend, so client code never
# needs to know the backend's real host.
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_MEDIA_BASE_URL=/media
NEXT_PUBLIC_SITE_URL=https://toiletman.uz
