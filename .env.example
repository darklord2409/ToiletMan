# Copy this file to .env and fill in real values before starting the stack.

# --- App ---
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# --- Postgres ---
POSTGRES_USER=tipobot
POSTGRES_PASSWORD=tipobot
POSTGRES_DB=tipobot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Telegram Bot ---
BOT_TOKEN=
# Public HTTPS URL of the deployed Mini App (e.g. a tunnel URL in dev, the
# real domain in prod). Leave blank locally to skip showing the "Open Shop"
# button — Telegram rejects non-https web_app URLs outright.
WEBAPP_URL=

# --- Ports exposed on the host ---
BACKEND_PORT=8000
ADMIN_PORT=5173
MINIAPP_PORT=5174
