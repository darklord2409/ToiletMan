# Copy this file to .env and fill in real values before starting the stack.
#
# This same file drives BOTH docker-compose.yml (local dev) and
# docker-compose.prod.yml (production) — the values below are the local-dev
# defaults; see the "PRODUCTION" notes next to each var for what to change
# when deploying for real.

# --- App ---
ENVIRONMENT=local
# PRODUCTION: set to "production" — flips FastAPI's debug mode off and is
# used elsewhere to branch dev-only behavior.
DEBUG=true
# PRODUCTION: set to "false". Leaving debug tracebacks/reload on in
# production leaks internals (stack traces, source paths) to anyone who
# can trigger a 500.
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
# PRODUCTION: generate a real secret and never reuse the dev one:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Rotating this invalidates every issued JWT (all customers/admins get
# logged out) — expected once, not something to do casually afterwards.

# --- Postgres ---
POSTGRES_USER=tipobot
POSTGRES_PASSWORD=tipobot
POSTGRES_DB=tipobot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# PRODUCTION: set a real POSTGRES_PASSWORD (long random string) — the dev
# default is intentionally trivial and is fine ONLY because postgres isn't
# published to the host in docker-compose.prod.yml.

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# PRODUCTION: set a REDIS_PASSWORD too (requires adding
# `--requirepass ${REDIS_PASSWORD}` to the redis service's command in
# docker-compose.prod.yml) if Redis will ever be reachable outside the
# compose network.

# --- Telegram Bot ---
BOT_TOKEN=
# Public HTTPS URL of the deployed Mini App (e.g. a tunnel URL in dev, the
# real domain in prod). Leave blank locally to skip showing the "Open Shop"
# button — Telegram rejects non-https web_app URLs outright.
WEBAPP_URL=

# --- CORS ---
# PRODUCTION: comma-separated list of the real frontend origins, e.g.
#   CORS_ORIGINS=https://shop.example.com,https://admin.example.com
# Not set locally — the backend's default (localhost:5173/3000) already
# covers the dev admin origin, and the miniapp/admin dev servers proxy
# API calls same-origin so CORS never applies to them locally.
CORS_ORIGINS=

# --- Ports exposed on the host ---
BACKEND_PORT=8000
ADMIN_PORT=5173
MINIAPP_PORT=5174
